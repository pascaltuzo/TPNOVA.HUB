<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TP NOVA HUB | Contact</title>

  <!-- Font Awesome -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family: Arial, sans-serif;
      background:#f4f7fb;
      padding:40px;
    }

    h1{
      text-align:center;
      margin-bottom:40px;
      color:#222;
      font-size:42px;
    }

    .contact-container{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
      gap:25px;
      max-width:1400px;
      margin:auto;
    }

    .contact-box{
      background:white;
      border-radius:20px;
      padding:30px 20px;
      text-align:center;
      box-shadow:0 5px 15px rgba(0,0,0,0.08);
      transition:0.3s;
    }

    .contact-box:hover{
      transform:translateY(-8px);
      box-shadow:0 10px 25px rgba(0,0,0,0.15);
    }

    .contact-box i{
      font-size:45px;
      margin-bottom:20px;
    }

    .contact-box h3{
      margin-bottom:12px;
      color:#222;
      font-size:22px;
    }

    .contact-box a{
      text-decoration:none;
      color:#555;
      font-size:16px;
      word-break:break-word;
    }

    .contact-box a:hover{
      color:#007bff;
    }

    /* Social Colors */

    .fa-envelope{ color:#e63946; }
    .fa-phone{ color:#2a9d8f; }
    .fa-instagram{ color:#d6249f; }
    .fa-facebook{ color:#1877f2; }
    .fa-x-twitter{ color:#000; }
    .fa-whatsapp{ color:#25d366; }
    .fa-youtube{ color:#ff0000; }
    .fa-linkedin{ color:#0077b5; }
    .fa-telegram{ color:#229ed9; }
    .fa-github{ color:#333; }
    .fa-tiktok{ color:#000; }
    .fa-threads{ color:#000; }

  </style>
</head>

<body>

  <h1>Contact TP NOVA HUB</h1>

  <div class="contact-container">

    <!-- Email -->
    <div class="contact-box">
      <i class="fas fa-envelope"></i>
      <h3>Email</h3>
      <a href="mailto:pascaltuzo@gmail.com">
        pascaltuzo@gmail.com
      </a>
    </div>

    <!-- Phone -->
    <div class="contact-box">
      <i class="fas fa-phone"></i>
      <h3>Phone</h3>
      <a href="tel:+255769123922">
        +255 769 123 922
      </a>
    </div>

    <!-- Instagram -->
    <div class="contact-box">
      <i class="fab fa-instagram"></i>
      <h3>Instagram</h3>
      <a href="https://www.instagram.com/tpnova.hub/" target="_blank">
        @tpnova.hub
      </a>
    </div>

    <!-- Facebook -->
    <div class="contact-box">
      <i class="fab fa-facebook"></i>
      <h3>Facebook</h3>
     <a href="https://www.facebook.com/TPNOVAHUB" target="_blank">
    TP NOVA HUB
  </a>
    </div>

    <!-- Threads -->
    <div class="contact-box">
      <i class="fab fa-threads"></i>
      <h3>Threads</h3>
      <a href="https://www.threads.net/" target="_blank">
        @tpnova.hub
      </a>
    </div>

    <!-- X -->
    <div class="contact-box">
      <i class="fab fa-x-twitter"></i>
      <h3>X (Twitter)</h3>
      <a href="https://x.com/" target="_blank">
        @TPNOVAHUB
      </a>
    </div>

    <!-- WhatsApp -->
    <div class="contact-box">
      <i class="fab fa-whatsapp"></i>
      <h3>WhatsApp</h3>
     <a href="https://wa.me/255769123922" target="_blank">
    Chat on WhatsApp
  </a>
    </div>

    <!-- TikTok -->
    <div class="contact-box">
      <i class="fab fa-tiktok"></i>
      <h3>TikTok</h3>
      <a href="https://www.tiktok.com/" target="_blank">
        @TPNOVAHUB
      </a>
    </div>

    <!-- YouTube -->
    <div class="contact-box">
      <i class="fab fa-youtube"></i>
      <h3>YouTube</h3>
      <a href="https://www.youtube.com/" target="_blank">
        TP NOVA HUB
      </a>
    </div>

    <!-- LinkedIn -->
    <div class="contact-box">
      <i class="fab fa-linkedin"></i>
      <h3>LinkedIn</h3>
      <a href="https://www.linkedin.com/" target="_blank">
        TP NOVA HUB
      </a>
    </div>

    <!-- Telegram -->
    <div class="contact-box">
      <i class="fab fa-telegram"></i>
      <h3>Telegram</h3>
      <a href="https://t.me/" target="_blank">
        @TPNOVAHUB
      </a>
    </div>

    <!-- GitHub -->
    <div class="contact-box">
      <i class="fab fa-github"></i>
      <h3>GitHub</h3>
      <a href="https://github.com/" target="_blank">
        TPNOVAHUB
      </a>
    </div>

  </div>

</body>
</html>