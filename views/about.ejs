<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>About - TPNOVA HUB</title>

<style>

body{
  font-family:Arial, sans-serif;
  margin:0;
  background:#f4f7fb;
}

/* HEADER */
.header{
  background:#0f0f0f;
  color:white;
  padding:30px;
  text-align:center;
}

.header h1{
  margin:0;
  font-size:40px;
}

/* CONTAINER */
.container{
  max-width:1000px;
  margin:40px auto;
  padding:20px;
}

/* CARDS */
.card{
  background:white;
  padding:25px;
  margin-bottom:20px;
  border-radius:12px;
  box-shadow:0 4px 10px rgba(0,0,0,0.1);
}

.card h2{
  color:#007bff;
  margin-bottom:10px;
}

.card p{
  line-height:1.6;
  color:#444;
}

/* GRID */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(300px, 1fr));
  gap:20px;
}

.btn{
  display:inline-block;
  margin-top:15px;
  padding:10px 20px;
  background:#007bff;
  color:white;
  text-decoration:none;
  border-radius:25px;
}

.btn:hover{
  background:#0056b3;
}

</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
  <h1>About TPNOVA HUB</h1>
  <p>Building modern digital solutions for businesses</p>
</div>

<!-- CONTENT -->
<div class="container">

  <!-- WHO WE ARE -->
  <div class="card">
    <h2>Who We Are</h2>
    <p>
      TPNOVA HUB is a creative digital agency specializing in website development,
      branding, UI/UX design, and business digital solutions. We help businesses
      transform their ideas into powerful online experiences.
    </p>
  </div>

  <!-- MISSION & VISION -->
  <div class="grid">

    <!-- MISSION -->
    <div class="card">
      <h2>Our Mission</h2>
      <p>
        To empower businesses with modern, fast, and scalable digital solutions
        that improve visibility, growth, and customer engagement in the online world.
      </p>
    </div>

    <!-- VISION -->
    <div class="card">
      <h2>Our Vision</h2>
      <p>
        To become a leading digital innovation hub in Africa,
        delivering world-class technology solutions that transform businesses globally.
      </p>
    </div>

  </div>

  <!-- CTA -->
  <div class="card" style="text-align:center;">
    <h2>Let’s Build Something Great</h2>
    <p>Ready to grow your business online? Contact us today.</p>

    <a href="/contact" class="btn">Contact Us</a>
  </div>

</div>

</body>
</html>