<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title || "TPNOVA HUB" %></title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

/* RESET */
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f5f7fb;
}

/* ================= NAVBAR ================= */
.navbar{
    position:fixed;
    top:0;
    width:100%;
    height:70px;
    background:#0f172a;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 20px;
    z-index:1000;
    color:white;
}

/* LOGO */
.logo{
    display:flex;
    align-items:center;
    gap:10px;
}

.logo img{
    width:40px;
    height:40px;
    border-radius:50%;
}

.logo h2{
    font-size:18px;
}

/* NAV LINKS */
.nav-links{
    display:flex;
    align-items:center;
}

.nav-links a{
    color:white;
    text-decoration:none;
    margin:0 10px;
}

/* BUTTON */
.btn{
    padding:10px 18px;
    border:none;
    border-radius:25px;
    cursor:pointer;
}

.btn-blue{
    background:#2563eb;
    color:white;
}

/* HAMBURGER */
.hamburger{
    display:none;
    font-size:24px;
    cursor:pointer;
}

/* MOBILE MENU */
.mobile-menu{
    position:fixed;
    top:70px;
    right:-100%;
    width:250px;
    height:100vh;
    background:#111827;
    display:flex;
    flex-direction:column;
    padding:20px;
    transition:0.3s;
}

.mobile-menu a{
    color:white;
    text-decoration:none;
    padding:12px;
    border-bottom:1px solid #333;
}

/* HERO */
.hero{
    height:100vh;
    background:linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),
    url('https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=1400') center/cover;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero h1{
    font-size:55px;
}

.hero span{
    color:#2563eb;
}

.hero-buttons{
    margin-top:20px;
}

/* SERVICES */
.services{
    padding:80px 20px;
    text-align:center;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    margin-top:40px;
}

.card{
    background:white;
    padding:20px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.card img{
    width:100%;
    height:150px;
    object-fit:cover;
    border-radius:10px;
    margin-bottom:10px;
}

/* MODAL */
.modal{
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.7);
    justify-content:center;
    align-items:center;
}

.modal-box{
    background:white;
    width:90%;
    max-width:500px;
    padding:25px;
    border-radius:12px;
}

input, select, textarea{
    width:100%;
    padding:10px;
    margin:10px 0;
}

/* FOOTER */
footer{
    text-align:center;
    padding:20px;
    background:#111827;
    color:white;
}

/* RESPONSIVE */
@media(max-width:768px){
    .nav-links{
        display:none;
    }
    .hamburger{
        display:block;
    }
}

</style>
</head>

<body>

<!-- NAVBAR -->
<div class="navbar">

    <!-- LOGO -->
    <div class="logo">
        <img src="https://cdn-icons-png.flaticon.com/512/5968/5968705.png" alt="logo">
        <h2>TPNOVA HUB</h2>
    </div>

    <!-- NAV LINKS -->
    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/portfolio">Portfolio</a>
        <a href="/contact">Contact</a>
        <button class="btn btn-blue" onclick="openLogin()">Admin</button>
    </div>

    <!-- HAMBURGER -->
    <div class="hamburger" onclick="toggleMenu()">
        <i class="fa fa-bars"></i>
    </div>

</div>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/contact">Contact</a>
    <button class="btn btn-blue" onclick="openLogin()">Admin</button>
</div>

<!-- HERO -->
<section class="hero">

    <div>
        <h1>Build Your <span>Digital Future</span></h1>
        <p>Modern websites, branding and digital solutions</p>

        <div class="hero-buttons">
            <button class="btn btn-blue" onclick="openBooking()">Book Service</button>
            <a href="/portfolio">
                <button class="btn" style="background:#16a34a;color:white;">
                    View Portfolio
                </button>
            </a>
        </div>
    </div>

</section>

<!-- SERVICES -->
<section class="services">

    <h2>Our Services</h2>

    <div class="grid">

        <div class="card">
            <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f" alt="">
            <h3>Web Development</h3>
            <p>Modern responsive websites</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1558655146-d09347e92766" alt="">
            <h3>Graphic Design</h3>
            <p>Logos and branding</p>
        </div>

        <div class="card">
            <img src="https://images.unsplash.com/photo-1559028012-481c04fa702d" alt="">
            <h3>UI/UX Design</h3>
            <p>User-friendly interfaces</p>
        </div>

    </div>

</section>

<!-- BOOKING MODAL -->
<div class="modal" id="bookingModal">

    <div class="modal-box">
        <h2>Book Service</h2>

        <form action="/book" method="POST">

            <input type="text" name="full_name" placeholder="Full Name" required>
            <input type="email" name="email" placeholder="Email">
            <input type="text" name="phone" placeholder="Phone">

            <select name="service" required>
                <option value="">Select Service</option>
                <option>Web Development</option>
                <option>Graphic Design</option>
                <option>UI/UX Design</option>
            </select>

            <textarea name="message" placeholder="Message"></textarea>

            <button class="btn btn-blue" type="submit">Submit Booking</button>

        </form>

        <button onclick="closeBooking()" class="btn" style="background:red;color:white;margin-top:10px;">
            Close
        </button>
    </div>

</div>

<!-- LOGIN MODAL -->
<div class="modal" id="loginModal">

    <div class="modal-box">
        <h2>Admin Login</h2>

        <input type="email" id="email" placeholder="Email">
        <input type="password" id="password" placeholder="Password">

        <button class="btn btn-blue" onclick="loginAdmin()">Login</button>

        <button onclick="closeLogin()" class="btn" style="background:red;color:white;margin-top:10px;">
            Close
        </button>
    </div>

</div>

<!-- FOOTER -->
<footer>
    © 2026 TPNOVA HUB
</footer>

<script>

/* MODALS */
function openBooking(){
    document.getElementById("bookingModal").style.display="flex";
}

function closeBooking(){
    document.getElementById("bookingModal").style.display="none";
}

function openLogin(){
    document.getElementById("loginModal").style.display="flex";
}

function closeLogin(){
    document.getElementById("loginModal").style.display="none";
}

/* LOGIN */
function loginAdmin(){
    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    if(email === "pascaltuzo@gmail.com" && password === "Tuzo12*#"){
        window.location.href="/admin";
    } else {
        alert("Invalid credentials");
    }
}

/* MOBILE MENU */
function toggleMenu(){
    let menu = document.getElementById("mobileMenu");

    if(menu.style.right === "0px"){
        menu.style.right = "-100%";
    } else {
        menu.style.right = "0px";
    }
}

</script>

</body>
</html>