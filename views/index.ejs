<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TPNOVA HUB</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<style>

/* RESET */
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Arial, sans-serif;
}

body{
  background:#f4f7fb;
}

/* ===== TOP BAR ===== */
.topbar{
  position:fixed;
  top:0;
  width:100%;
  height:70px;
  background:#0f0f0f;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 20px;
  z-index:1000;
  color:white;
}

/* LEFT SECTION */
.left-section{
  display:flex;
  align-items:center;
  gap:15px;
}

/* MENU ICON */
.menu-lines{
  font-size:26px;
  cursor:pointer;
  padding:6px 10px;
}

/* LOGO */
.logo-box{
  width:35px;
  height:35px;
  background:#007bff;
  border-radius:8px;
}

/* COMPANY NAME */
.company-name{
  font-size:20px;
  font-weight:bold;
  letter-spacing:1px;
}

/* RIGHT NAV LINKS */
.nav-links{
  display:flex;
  gap:20px;
  align-items:center;
}

.nav-links a{
  color:white;
  text-decoration:none;
  font-size:15px;
  transition:0.3s;
}

.nav-links a:hover{
  color:#007bff;
}

/* SIDEBAR */
.sidebar{
  position:fixed;
  top:0;
  left:-260px;
  width:260px;
  height:100%;
  background:#1c1c1c;
  padding-top:80px;
  transition:0.4s;
  z-index:999;
}

.sidebar.active{
  left:0;
}

.sidebar a{
  display:block;
  color:white;
  padding:15px;
  text-decoration:none;
  border-bottom:1px solid #333;
}

.sidebar a:hover{
  background:#007bff;
}

/* HERO SECTION */
.hero{
  height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  padding:20px;
  color:white;
  background:linear-gradient(rgba(0,0,0,0.65),
  rgba(0,0,0,0.65)),
  url('https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=1400')
  center/cover;
}

.hero h1{
  font-size:55px;
  margin-bottom:15px;
}

.hero p{
  max-width:700px;
  font-size:18px;
  line-height:1.6;
  margin-bottom:25px;
}

/* BUTTONS */
.btn-container{
  display:flex;
  gap:15px;
}

.btn{
  padding:14px 28px;
  border-radius:30px;
  border:none;
  cursor:pointer;
  font-size:17px;
}

.btn-primary{
  background:#007bff;
  color:white;
}

.btn-secondary{
  background:white;
  color:#111;
}

/* MODAL */
.modal{
  display:none;
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.75);
  justify-content:center;
  align-items:center;
  z-index:2000;
}

.modal-box{
  background:white;
  width:90%;
  max-width:500px;
  padding:30px;
  border-radius:15px;
}

.modal-box h2{
  text-align:center;
  margin-bottom:20px;
}

.modal-box input,
.modal-box select,
.modal-box textarea{
  width:100%;
  padding:12px;
  margin-bottom:12px;
  border-radius:8px;
  border:1px solid #ccc;
}

.modal-box button{
  width:100%;
  padding:12px;
  border:none;
  background:#007bff;
  color:white;
  border-radius:8px;
  cursor:pointer;
}

.close-btn{
  background:red !important;
  margin-top:10px;
}

/* FOOTER */
footer{
  text-align:center;
  padding:20px;
  background:#111;
  color:white;
}

</style>
</head>

<body>

<!-- TOP BAR -->
<div class="topbar">

  <!-- LEFT -->
  <div class="left-section">
    <div class="menu-lines" onclick="toggleMenu()">☰</div>
    <div class="logo-box"></div>
    <div class="company-name">TPNOVA HUB</div>
  </div>

  <!-- RIGHT NAV -->
  <div class="nav-links">
    <a href="/">Home</a>
    <a href="/about">About</a>
    <a href="/services">Services</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/contact">Contact</a>
  </div>

</div>

<!-- SIDEBAR -->
<div id="sidebar" class="sidebar">
  <a href="/">Home</a>
  <a href="/about">About</a>
  <a href="/services">Services</a>
  <a href="/portfolio">Portfolio</a>
  <a href="/contact">Contact</a>
</div>

<!-- HERO -->
<section class="hero">

  <h1>Build Your Digital Future</h1>

  <p>
    TPNOVA HUB delivers modern websites, branding systems,
    and powerful digital solutions that grow your business online.
  </p>

  <div class="btn-container">

    <button class="btn btn-primary" onclick="openModal()">
      Book Service
    </button>

    <a href="/portfolio" class="btn btn-secondary">
      View Portfolio
    </a>

  </div>

</section>

<!-- MODAL FORM -->
<div id="modal" class="modal">

  <div class="modal-box">

    <h2>Book Your Service</h2>

    <input type="text" placeholder="Full Name">
    <input type="email" placeholder="Email Address">
    <input type="tel" placeholder="Phone Number">

    <select>
      <option>Select Service</option>
      <option>Website Development</option>
      <option>Graphic Design</option>
      <option>Branding</option>
      <option>UI/UX Design</option>
    </select>

    <textarea rows="4" placeholder="Project Details"></textarea>

    <button>Submit Booking</button>

    <button class="close-btn" onclick="closeModal()">
      Close
    </button>

  </div>

</div>

<!-- FOOTER -->
<footer>
  © 2026 TPNOVA HUB | All Rights Reserved
</footer>

<script>

function toggleMenu(){
  document.getElementById("sidebar").classList.toggle("active");
}

function openModal(){
  document.getElementById("modal").style.display="flex";
}

function closeModal(){
  document.getElementById("modal").style.display="none";
}

</script>

</body>
</html>