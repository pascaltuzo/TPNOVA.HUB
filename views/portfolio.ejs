<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Portfolio | TPNOVA HUB</title>

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#f4f7fb;
}

/* ===============================
HEADER
=============================== */
.header{
    text-align:center;
    padding:120px 20px 40px;
}

.header h1{
    font-size:40px;
    margin-bottom:10px;
    color:#0f172a;
}

.header p{
    color:gray;
    font-size:16px;
}

/* ===============================
GRID
=============================== */
.portfolio-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:25px;
    padding:30px;
}

/* ===============================
CARD
=============================== */
.portfolio-card{
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    transition:0.4s;
    position:relative;
}

.portfolio-card:hover{
    transform:translateY(-8px);
}

/* ===============================
SLIDER
=============================== */
.slider{
    position:relative;
    width:100%;
    height:350px;
    overflow:hidden;
    background:#eee;
}

.slide{
    position:absolute;
    width:100%;
    height:100%;
    object-fit:contain;
    opacity:0;
    transition:opacity 1s ease-in-out;
    background:#f5f5f5;
}

.slide.active{
    opacity:1;
}

/* ===============================
CONTENT
=============================== */
.content{
    padding:20px;
}

.content h2{
    margin-bottom:10px;
    color:#0f172a;
}

.category{
    color:#2563eb;
    font-size:14px;
    margin-bottom:10px;
    font-weight:bold;
}

.description{
    font-size:14px;
    line-height:1.6;
    color:#444;
}

.date{
    margin-top:15px;
    display:block;
    color:gray;
    font-size:12px;
}

/* ===============================
NO DATA
=============================== */
.no-data{
    text-align:center;
    padding:50px;
    color:gray;
    font-size:18px;
}

</style>
</head>

<body>

<!-- ===============================
HEADER
=============================== -->
<div class="header">

    <h1>Our Portfolio</h1>

    <p>
        Here are some of our recent projects.
    </p>

</div>

<!-- ===============================
PORTFOLIO GRID
=============================== -->
<div class="portfolio-grid">

<% if (portfolio && portfolio.length > 0) { %>

    <% portfolio.forEach((project, index) => { %>

        <div class="portfolio-card">

            <!-- ===============================
            IMAGE SLIDER
            =============================== -->
            <div class="slider">

                <% project.images.forEach((img, imgIndex) => { %>

                    <img 
                        src="/uploads/<%= img %>"
                        class="slide slider-<%= index %> <%= imgIndex === 0 ? 'active' : '' %>"
                    >

                <% }) %>

            </div>

            <!-- ===============================
            CONTENT
            =============================== -->
            <div class="content">

                <h2>
                    <%= project.title %>
                </h2>

                <div class="category">
                    <%= project.category %>
                </div>

                <div class="description">
                    <%= project.description %>
                </div>

                <small class="date">
                    Uploaded:
                    <%= new Date(project.created_at).toLocaleString() %>
                </small>

            </div>

        </div>

    <% }) %>

<% } else { %>

    <div class="no-data">

        No portfolio projects found.

    </div>

<% } %>

</div>

<!-- ===============================
SLIDER SCRIPT
=============================== -->
<script>

// GET ALL SLIDERS
const portfolioProjects = document.querySelectorAll(".slider");

portfolioProjects.forEach((slider, index) => {

    const slides = slider.querySelectorAll(".slide");

    let currentSlide = 0;

    // ONLY START IF MORE THAN 1 IMAGE
    if(slides.length > 1){

        setInterval(() => {

            // REMOVE ACTIVE
            slides[currentSlide]
            .classList.remove("active");

            // NEXT SLIDE
            currentSlide =
                (currentSlide + 1) % slides.length;

            // SHOW NEXT
            slides[currentSlide]
            .classList.add("active");

        }, 5000);

    }

});

</script>

</body>
</html>